# SQLAdvisor 개발 환경 템플릿입니다.
# 이 파일을 deploy/.env.dev로 복사한 뒤 사용할 항목만 채우세요.
# 실제 deploy/.env.dev 파일은 Git에 커밋하지 않습니다.
#
# 빠른 선택
# - 인증: APP_AUTH_ENABLED=false, 또는 true + APP_AUTH_MODE=external|internal
# - LLM: AWR_LLM_PROVIDER=local|openai|gemini|internal|ollama
# - 임베딩: AWR_EMBEDDING_PROVIDER=none|openai|gemini|internal|ollama
#
# AI 설정 반영 방식
# - API가 시작될 때 비어 있지 않은 AI env 값은 awr_ai_setting DB에 반영됩니다.
# - 시작 후 Web AI Settings 화면에서 저장한 값도 awr_ai_setting DB에 반영됩니다.
# - 다시 시작하면 이 파일의 비어 있지 않은 AI env 값이 기준값으로 다시 반영됩니다.
#
# 참고
# - 활성 LLM provider와 embedding provider는 각각 하나만 선택합니다.
# - 선택한 provider 블록만 채우면 됩니다.
# - anthropic, xai, cohere 항목은 현재 예약/메타데이터 성격입니다.
#   현재 백엔드에서는 AWR_LLM_PROVIDER 값으로 사용할 수 없습니다.

# ==============================================================================
# AWR, RAG, Worker, OCR
# ==============================================================================
# AWR_LLM_PROVIDER: local | openai | gemini | internal | ollama
# AWR_EMBEDDING_PROVIDER: none | openai | gemini | internal | ollama
AWR_LLM_PROVIDER=local
AWR_EMBEDDING_PROVIDER=none

# 양의 정수입니다. 일반적으로 timeout은 30-120, top-k는 4-12 사이를 사용합니다.
AWR_AI_TIMEOUT_SECONDS=45
AWR_RAG_TOP_K=8

# Compose 내부 URL입니다. 일반 개발 compose에서는 기본값을 유지합니다.
AWR_WORKER_URL=http://worker:8081

# OCR_LANG 예: eng | kor | eng+kor
OCR_LANG=eng+kor
OCR_MAX_PAGES=20

# ==============================================================================
# Authentication
# ==============================================================================
# APP_AUTH_ENABLED: true | false. 비워두면 application-dev.yml 기본값 false를 사용합니다.
# APP_AUTH_MODE: external | internal
# - external: Google 로그인
# - internal: 내부 포털/프록시가 넘기는 loginEno 또는 X-Login-Eno 기반 AD 식별자 로그인
APP_AUTH_ENABLED=
APP_AUTH_MODE=external

# APP_AUTH_MODE=external일 때만 필요합니다.
GOOGLE_CLIENT_ID=

# 콤마로 구분합니다. APP_ALLOWED_GOOGLE_DOMAINS를 비우면 GOOGLE_CLIENT_ID로
# 검증된 Google 계정을 도메인 제한 없이 허용합니다.
APP_ALLOWED_GOOGLE_DOMAINS=
APP_ADMIN_EMAILS=

# APP_AUTH_MODE=internal에서 loginEno에 이메일 도메인이 없을 때 붙일 도메인입니다.
APP_INTERNAL_AUTH_EMAIL_DOMAIN=internal.local

APP_LOCAL_LOGIN_ENABLED=false
APP_SESSION_TIMEOUT_MINUTES=120

# ==============================================================================
# Provider: OpenAI
# ==============================================================================
# AWR_LLM_PROVIDER=openai 또는 AWR_EMBEDDING_PROVIDER=openai일 때 필요합니다.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# rag_chunk.embedding 컬럼은 VECTOR(1536)입니다. DB 스키마도 함께 바꾸는 경우가 아니면 1536을 유지합니다.
OPENAI_EMBEDDING_DIMENSION=1536

# ==============================================================================
# Provider: Gemini
# ==============================================================================
# AWR_LLM_PROVIDER=gemini 또는 AWR_EMBEDDING_PROVIDER=gemini일 때 필요합니다.
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-3.1-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ==============================================================================
# Provider: Internal OpenAI-compatible
# ==============================================================================
# AWR_LLM_PROVIDER=internal일 때 필요합니다.
INTERNAL_LLM_API_KEY=

# 허용되는 chat URL 형식:
# - http://host:port
# - http://host:port/v1/chat/completions
INTERNAL_LLM_BASE_URL=
INTERNAL_LLM_CHAT_MODEL=gemma4-31b

# AWR_EMBEDDING_PROVIDER=internal일 때 필요합니다.
# 허용되는 embedding URL 형식:
# - http://host:port
# - http://host:port/embeddings
INTERNAL_EMBEDDING_BASE_URL=
INTERNAL_EMBEDDING_MODEL=genai-bge-m3

# ==============================================================================
# Provider: Ollama
# ==============================================================================
# Ollama가 Docker 호스트에서 실행 중이면 host.docker.internal을 사용합니다.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=embeddinggemma

# ==============================================================================
# Reserved / Future Providers
# ==============================================================================
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-latest

XAI_API_KEY=
XAI_CHAT_MODEL=grok-2-latest

COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-multilingual-v3.0
